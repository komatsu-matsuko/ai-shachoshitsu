# 日次売上 自動投入スクリプト用の環境変数サンプル
# 本番では .env にコピーし、値を入れる。.env は git にコミットしないこと。

# === エアレジ ===
# バックオフィス「設定」→「他システム連携［データ連携API］」で発行
AIRREGI_API_KEY=
AIRREGI_API_TOKEN=

# === Uber Eats (Reporting API) ===
# https://developer.uber.com/ でアプリ作成・Eats スコープ取得
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
# または取得済みのトークン
# UBER_ACCESS_TOKEN=

# === LINE (Messaging API 統計) ===
# LINE Developers でチャネル作成 → Channel Access Token (長期)
LINE_CHANNEL_ACCESS_TOKEN=

# === Google Sheets ===
# サービスアカウントの JSON キーファイルのパス
# 例: ./credentials/sheets-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=
# 書き込むスプレッドシートの ID（URL の /d/ と /edit の間）
GOOGLE_SHEET_ID=16nmlFxS85gxzGIFqcxKzHW4845plF3yKuS3WX8vkRrk
# シート名（タブ名）または gid
GOOGLE_SHEET_NAME=日次売上報告
